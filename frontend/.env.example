# =============================================================================
# Frontend environment template. Copy to `.env.local` for local dev.
# Vite inlines anything prefixed with VITE_ at build time.
# =============================================================================

# Local dev points at the local FastAPI server.
VITE_API_URL=http://localhost:8000

# Production: passed at build time via `vercel --build-env VITE_API_URL=...`.
# VITE_API_URL=https://your-backend.up.railway.app

# Optional: enable Sentry in the frontend. Leave unset to disable.
# VITE_SENTRY_DSN=https://...@sentry.io/...
