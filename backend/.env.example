# =============================================================================
# Backend environment template. Copy to `.env` and fill in real values.
# Never commit a populated `.env`.
# =============================================================================

# --- Azure AD auth (required) ------------------------------------------------
AZURE_AD_TENANT_ID=d1aec0dc-1c2b-4541-9724-3a6f21519d9e
AZURE_AD_CLIENT_ID=0b7fb923-f379-4245-b319-a9c1725af4f5

# --- Database (required) -----------------------------------------------------
# Production: private PostgreSQL on Azure (VNet-only).
# Local dev: use a local Postgres instance.
DATABASE_URL=postgresql://user:password@localhost/i3space

# --- Bootstrap user (optional) -----------------------------------------------
# Seeds the first row in the users table on startup if the table is empty.
# Only needed on first deploy; leave blank once the table is populated.
INITIAL_USER_EMAIL=
INITIAL_USER_PASSWORD=

# --- CORS --------------------------------------------------------------------
# Comma-separated list of allowed origins.
ALLOWED_ORIGINS=http://localhost:5173
# Set to "false" once you have a stable custom domain.
ALLOW_PAGES_PREVIEWS=true

# --- Rate limiting (optional) ------------------------------------------------
LOGIN_RATE_LIMIT=5/minute

# --- Observability (optional) ------------------------------------------------
LOG_LEVEL=INFO
APP_VERSION=0.3.0
APP_ENV=development
# Leave SENTRY_DSN unset to disable Sentry entirely.
# SENTRY_DSN=https://...@sentry.io/...
# SENTRY_TRACES_SAMPLE_RATE=0.05
