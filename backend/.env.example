# =============================================================================
# Backend environment template. Copy to `.env` and fill in real values.
# Never commit a populated `.env`.
# =============================================================================

# --- Google Sheets (required) ------------------------------------------------
SPREADSHEET_ID=1XDSB_93xKEcM28GZ1ZtVUhhu6MEbouTbUIGwlOlfvHo
SHEET_NAME=Sheet1
TRACKER_SHEET_NAME=youtube_tracker
CHANNELS_SHEET_NAME=channels

# Local dev: path to a service account JSON file with Editor on the spreadsheet.
GOOGLE_APPLICATION_CREDENTIALS=credentials/service_account.json
# Production (Railway): paste the full single-line JSON instead of using the file.
# GOOGLE_CREDENTIALS_JSON={"type":"service_account",...}

# --- Auth (required for production) ------------------------------------------
# 32+ random bytes. Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-to-something-long-and-random
# Optional: token lifetime in seconds. Default 604800 (7 days).
JWT_EXPIRES_SECONDS=604800
# Optional: slowapi rate limit on /auth/login. Default "5/minute".
LOGIN_RATE_LIMIT=5/minute

# --- CORS --------------------------------------------------------------------
# Comma-separated list of explicit allowed origins.
ALLOWED_ORIGINS=http://localhost:5173
# Set to "false" in production once you have a stable custom domain.
ALLOW_VERCEL_PREVIEWS=true

# --- Observability (optional) ------------------------------------------------
LOG_LEVEL=INFO
APP_VERSION=0.2.0
APP_ENV=development
# Leave SENTRY_DSN unset to disable Sentry entirely.
# SENTRY_DSN=https://...@sentry.io/...
# SENTRY_TRACES_SAMPLE_RATE=0.05
